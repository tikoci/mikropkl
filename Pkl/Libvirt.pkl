/// Libvirt XML domain configuration derived from UTM pkl config attributes.
/// Only QEMU backend is supported (libvirt does not use Apple Hypervisor.framework).
/// Used to generate a libvirt.xml alongside the UTM bundle so the same disk images
/// can be started with `virsh define libvirt.xml && virsh start <name>`.
module Libvirt

import "UTM.pkl"

/// Map drive index to a device letter (0->a, 1->b, ...)
local function indexToLetter(idx: Int): String =
  List("a","b","c","d","e","f","g","h","i","j","k","l","m","n","o","p")[idx]

/// Render a single <disk> element.
/// aarch64: uses NVMe bus to match UTM config.plist Interface=NVMe (RouterOS CHR on ARM requires NVMe)
/// x86_64: standard virtio-blk
local function diskElement(idx: Int, imageName: String, architecture: UTM.SystemArchitecture): String =
  let (fmt = if (idx == 0) "raw" else "qcow2")
  "    <disk type=\"file\" device=\"disk\">\n" +
  "      <driver name=\"qemu\" type=\"\(fmt)\"/>\n" +
  // /LIBVIRT_DATA_PATH is a placeholder replaced by `make libvirt-fixpaths`
  // (or manually) with the absolute path to the .utm bundle's Data directory
  "      <source file=\"/LIBVIRT_DATA_PATH/\(imageName)\"/>\n" +
  (if (architecture == "aarch64")
    "      <target dev=\"nvme\(idx)n1\" bus=\"nvme\"/>\n"
  else
    "      <target dev=\"vd\(indexToLetter(idx))\" bus=\"virtio\"/>\n") +
  "    </disk>\n"

/// Render the <os> block.  aarch64 uses firmware="efi" so libvirt auto-selects
/// the UEFI pflash loader/nvram paths; x86_64 uses plain hvm (SeaBIOS).
local function osBlock(architecture: UTM.SystemArchitecture): String =
  let (archQemu = if (architecture == "aarch64") "aarch64" else "x86_64")
  let (machineType = if (architecture == "aarch64") "virt" else "q35")
  if (architecture == "aarch64")
    "  <os firmware=\"efi\">\n" +
    "    <type arch=\"\(archQemu)\" machine=\"\(machineType)\">hvm</type>\n" +
    "  </os>\n"
  else
    "  <os>\n" +
    "    <type arch=\"\(archQemu)\" machine=\"\(machineType)\">hvm</type>\n" +
    "  </os>\n"

/// Render the serial + console devices.
/// aarch64/virt uses a PL011 UART (system-serial); x86_64/q35 uses ISA serial.
local function serialBlock(architecture: UTM.SystemArchitecture): String =
  if (architecture == "aarch64")
    "    <serial type=\"pty\">\n" +
    "      <target type=\"system-serial\" port=\"0\">\n" +
    "        <model name=\"pl011\"/>\n" +
    "      </target>\n" +
    "    </serial>\n" +
    "    <console type=\"pty\">\n" +
    "      <target type=\"serial\" port=\"0\"/>\n" +
    "    </console>\n"
  else
    "    <serial type=\"pty\">\n" +
    "      <target type=\"isa-serial\" port=\"0\">\n" +
    "        <model name=\"isa-serial\"/>\n" +
    "      </target>\n" +
    "    </serial>\n" +
    "    <console type=\"pty\">\n" +
    "      <target type=\"serial\" port=\"0\"/>\n" +
    "    </console>\n"

/// Build a complete libvirt XML domain string from UTM config fields.
/// driveImageNames: primary image filename first, then any additional qdiskN.qcow2 names.
function domain(
  vmName: String,
  architecture: UTM.SystemArchitecture,
  memMib: Int,
  cpuCount: Int,
  driveImageNames: List<String>,
  macAddress: String,
  notes: String
): String =
  let (archQemu = if (architecture == "aarch64") "aarch64" else "x86_64")
  let (emulatorBin = "/usr/bin/qemu-system-\(archQemu)")
  let (effectiveCpus = if (cpuCount == 0) 1 else cpuCount)
  let (disksXml = driveImageNames.mapIndexed((i, n) -> diskElement(i, n, architecture)).join(""))
  "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n" +
  "<!--\n" +
  "  Generated by mikropkl / Libvirt.pkl - machine: \(vmName)\n" +
  "  Usage:\n" +
  "    make libvirt-fixpaths   # update disk paths to absolute (run once after build)\n" +
  "    virsh define \(vmName).utm/libvirt.xml\n" +
  "    virsh start \(vmName)\n" +
  "-->\n" +
  "<domain type=\"qemu\">\n" +
  "  <name>\(vmName)</name>\n" +
  "  <description>\(notes)</description>\n" +
  "  <memory unit=\"MiB\">\(memMib)</memory>\n" +
  "  <vcpu placement=\"static\">\(effectiveCpus)</vcpu>\n" +
  osBlock(architecture) +
  "  <features>\n" +
  "    <acpi/>\n" +
  // aarch64 uses GIC (Generic Interrupt Controller), not x86 APIC
  (if (architecture == "aarch64") "" else "    <apic/>\n") +
  "  </features>\n" +
  "  <cpu mode=\"host-passthrough\" check=\"none\"/>\n" +
  "  <devices>\n" +
  "    <emulator>\(emulatorBin)</emulator>\n" +
  disksXml +
  "    <interface type=\"user\">\n" +
  "      <mac address=\"\(macAddress)\"/>\n" +
  "      <model type=\"virtio\"/>\n" +
  "    </interface>\n" +
  serialBlock(architecture) +
  "  </devices>\n" +
  "</domain>\n"
