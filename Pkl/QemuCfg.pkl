/// QEMU --readconfig INI and launch shell script, derived from UTM pkl config attributes.
/// Only QEMU backend is supported (Apple Hypervisor has no QEMU config equivalent).
///
/// Generates two files per QEMU machine inside the .utm bundle:
///   qemu.cfg  — QEMU --readconfig ini-format configuration
///   qemu.sh   — Shell launcher that handles platform-specific options
///               (UEFI firmware paths, KVM/TCG detection, etc.)
///
/// The .cfg covers what QEMU --readconfig can express in its ini format.
/// Some options (pflash, -netdev hostfwd, accel, display/serial) are not expressible
/// in --readconfig and must be passed on the command line — qemu.sh handles those.
module QemuCfg

import "UTM.pkl"

/// Map drive index to QEMU drive id
local function driveId(idx: Int): String = "drive\(idx)"

/// Render a [drive] + [device] section pair for a single disk.
/// aarch64: explicit virtio-blk-pci (if=virtio resolves to MMIO on virt, which fails).
/// x86_64: if=virtio shorthand is fine on q35 (resolves to virtio-blk-pci).
local function driveSections(idx: Int, imageName: String, architecture: UTM.SystemArchitecture): String =
  let (fmt = if (idx == 0) "raw" else "qcow2")
  let (id = driveId(idx))
  if (architecture == "aarch64")
    // aarch64: use if=none + explicit device to get virtio-blk-pci (not MMIO)
    """
    [drive "\(id)"]
      file = "./Data/\(imageName)"
      format = "\(fmt)"
      if = "none"

    [device "virtio-blk-\(id)"]
      driver = "virtio-blk-pci"
      drive = "\(id)"
    
    """
  else
    // x86_64 (q35): if=virtio resolves to virtio-blk-pci — simple and correct
    """
    [drive "\(id)"]
      file = "./Data/\(imageName)"
      format = "\(fmt)"
      if = "virtio"
    
    """

/// Build the complete QEMU --readconfig ini string.
function config(
  vmName: String,
  architecture: UTM.SystemArchitecture,
  memMib: Int,
  cpuCount: Int,
  driveImageNames: List<String>,
  macAddress: String,
  notes: String
): String =
  let (machineType = if (architecture == "aarch64") "virt" else "q35")
  let (effectiveCpus = if (cpuCount == 0) 1 else cpuCount)
  let (driveSectionsText = driveImageNames.mapIndexed((i, n) -> driveSections(i, n, architecture)).join(""))
  """
  # Generated by mikropkl / QemuCfg.pkl — machine: \(vmName)
  #
  # Usage:
  #   qemu-system-\(if (architecture == "aarch64") "aarch64" else "x86_64") --readconfig qemu.cfg [extra flags]
  #
  # NOTE: Some options cannot be expressed in --readconfig ini format:
  #   - UEFI pflash firmware (aarch64) — requires -drive if=pflash CLI args
  #   - Accelerator selection (KVM vs TCG) — requires -accel / -enable-kvm
  #   - User-mode networking with port forwarding — -netdev user,hostfwd=...
  #   - Display/serial redirection — -display none, -chardev, -serial
  # Use the companion qemu.sh script which handles all of the above.
  #
  # Disk paths are relative (./Data/...) — qemu.sh changes to this directory
  # before launching QEMU so relative paths resolve correctly.

  [machine]
    type = "\(machineType)"

  [memory]
    size = "\(memMib)M"

  [smp-opts]
    cpus = "\(effectiveCpus)"

  \(driveSectionsText)
  [device "nic0"]
    driver = "virtio-net-pci"
    netdev = "net0"
    mac = "\(macAddress)"

  """

/// Build the companion shell launcher script.
/// Handles platform-specific details that --readconfig cannot express:
///   - UEFI firmware discovery and pflash setup (aarch64)
///   - KVM/TCG accelerator detection
///   - User-mode networking with port forwarding
///   - Display/serial configuration for headless operation
function launchScript(
  vmName: String,
  architecture: UTM.SystemArchitecture,
  memMib: Int,
  cpuCount: Int,
  driveImageNames: List<String>,
  macAddress: String,
  notes: String
): String =
  let (archBin = if (architecture == "aarch64") "aarch64" else "x86_64")
  let (isArm = architecture == "aarch64")
  """
  #!/bin/sh
  # Generated by mikropkl / QemuCfg.pkl — machine: \(vmName)
  # Launches QEMU with the companion qemu.cfg and platform-specific flags.
  #
  # Usage:
  #   ./qemu.sh                     # foreground, serial on stdio
  #   ./qemu.sh --background        # background, serial to socket
  #   ./qemu.sh --port 9280         # custom host port (default: 9180)
  #   ./qemu.sh --dry-run           # print command without executing
  #
  # Environment variables:
  #   QEMU_BIN        — override qemu-system binary path
  #   QEMU_ACCEL      — override accelerator (kvm, hvf, tcg)
  #   QEMU_PORT       — override host port for RouterOS HTTP (default: 9180)
  #   QEMU_EXTRA      — additional QEMU arguments appended to command line
  \(if (isArm) "#   QEMU_EFI_CODE   — override UEFI code ROM path\n#   QEMU_EFI_VARS   — override UEFI vars template path" else "")

  set -eu

  # Resolve paths relative to this script (works when run from any directory)
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  CFG_FILE="$SCRIPT_DIR/qemu.cfg"

  # ── Parse arguments ──
  BACKGROUND=0
  DRY_RUN=0
  PORT="${QEMU_PORT:-9180}"
  while [ $# -gt 0 ]; do
    case "$1" in
      --background) BACKGROUND=1; shift ;;
      --dry-run)    DRY_RUN=1; shift ;;
      --port)       PORT="$2"; shift 2 ;;
      *)            echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  # ── Locate QEMU binary ──
  QEMU="${QEMU_BIN:-}"
  if [ -z "$QEMU" ]; then
    QEMU="$(command -v qemu-system-\(archBin) 2>/dev/null || true)"
    if [ -z "$QEMU" ]; then
      echo "ERROR: qemu-system-\(archBin) not found. Install QEMU or set QEMU_BIN." >&2
      exit 1
    fi
  fi

  # Change to script directory so relative paths in qemu.cfg (./Data/...) resolve correctly
  cd "$SCRIPT_DIR"

  # ── Accelerator detection ──
  ACCEL="${QEMU_ACCEL:-}"
  if [ -z "$ACCEL" ]; then
    HOST_ARCH="$(uname -m)"
    case "$(uname -s)" in
      Linux)
        # KVM only works when host and guest architectures match
        if [ -w /dev/kvm ] && [ "$HOST_ARCH" = "\(archBin)" ]; then
          ACCEL="kvm"
        else
          ACCEL="tcg,tb-size=256"
        fi
        ;;
      Darwin)
        # macOS: HVF only works natively (x86 on Intel, ARM on Apple Silicon)
        # Fall back to TCG for cross-architecture emulation
        if [ "$HOST_ARCH" = "x86_64" ] && [ "\(archBin)" = "x86_64" ]; then
          ACCEL="hvf"
        elif [ "$HOST_ARCH" = "arm64" ] && [ "\(archBin)" = "aarch64" ]; then
          ACCEL="hvf"
        else
          ACCEL="tcg,tb-size=256"
        fi
        ;;
      *)
        ACCEL="tcg,tb-size=256"
        ;;
    esac
  fi
  ACCEL_FLAGS="-accel $ACCEL"
  \(if (isArm)
  """

  # ── aarch64 UEFI firmware (pflash) ──
  # QEMU --readconfig cannot express pflash drives, so we handle it here.
  # Both pflash units must be identical size; vars file is a writable copy.
  EFI_CODE="${QEMU_EFI_CODE:-}"
  EFI_VARS_SRC="${QEMU_EFI_VARS:-}"
  if [ -z "$EFI_CODE" ]; then
    for p in \\
      /opt/homebrew/share/qemu/edk2-aarch64-code.fd \\
      /usr/local/share/qemu/edk2-aarch64-code.fd \\
      /usr/share/AAVMF/AAVMF_CODE.fd \\
      /usr/share/qemu-efi-aarch64/QEMU_EFI.fd \\
      /usr/share/edk2/aarch64/QEMU_EFI.fd; do
      if [ -f "$p" ]; then EFI_CODE="$p"; break; fi
    done
  fi
  if [ -z "$EFI_CODE" ]; then
    echo "ERROR: No UEFI firmware found for aarch64." >&2
    echo "Install: brew install qemu (macOS) or apt install qemu-efi-aarch64 (Linux)" >&2
    exit 1
  fi
  if [ -z "$EFI_VARS_SRC" ]; then
    for v in \\
      /opt/homebrew/share/qemu/edk2-arm-vars.fd \\
      /usr/local/share/qemu/edk2-arm-vars.fd \\
      /usr/share/AAVMF/AAVMF_VARS.fd \\
      /usr/share/qemu-efi-aarch64/QEMU_VARS.fd \\
      /usr/share/edk2/aarch64/QEMU_VARS.fd; do
      if [ -f "$v" ]; then EFI_VARS_SRC="$v"; break; fi
    done
  fi
  # Create writable copy of vars, sized to match code ROM
  VARS_COPY="/tmp/qemu-\(vmName)-vars.fd"
  if [ -n "$EFI_VARS_SRC" ]; then
    cp "$EFI_VARS_SRC" "$VARS_COPY"
  fi
  if [ "$BACKGROUND" = "0" ]; then
    trap 'rm -f "$VARS_COPY" 2>/dev/null' EXIT
  fi
  # stat follows symlinks (-L) — critical on ubuntu-24.04-arm where AAVMF_CODE.fd is a symlink
  CODE_SIZE="$(stat -Lc%s "$EFI_CODE" 2>/dev/null || stat -f%z "$EFI_CODE")"
  # Truncate/pad vars to match code ROM size (both pflash units must be identical)
  # Use dd for portability (truncate not available everywhere)
  dd if=/dev/zero of="$VARS_COPY" bs=1 count=0 seek="$CODE_SIZE" 2>/dev/null
  PFLASH_FLAGS="-drive if=pflash,format=raw,readonly=on,unit=0,file=$EFI_CODE"
  PFLASH_FLAGS="$PFLASH_FLAGS -drive if=pflash,format=raw,unit=1,file=$VARS_COPY"
  CPU_FLAGS="-cpu cortex-a710"
  MISC_FLAGS="-vga none"
  """
  else
  """

  # ── x86_64: SeaBIOS (QEMU default), no firmware flags needed ──
  PFLASH_FLAGS=""
  CPU_FLAGS=""
  MISC_FLAGS=""

  # ── Cross-arch workaround: x86_64 on non-x86 hosts ──
  # SeaBIOS q35 PCIe initialization plus default device probing (floppy, VGA,
  # parallel port, USB) is extremely slow under cross-arch TCG — x86 real-mode
  # I/O port emulation on ARM64 is much costlier than ARM MMIO on x86.
  # Two mitigations:
  #   1. pc (i440fx) machine type — simpler PIIX3 chipset, no PCIe topology
  #   2. -nodefaults — skip device probing for floppy, parallel, VGA, USB, etc.
  # The -serial flag still creates an ISA serial port despite -nodefaults.
  # Note: UTM itself uses -nodefaults -vga none for its QEMU launch commands.
  _XARCH="$(uname -m)"
  if [ "$_XARCH" != "x86_64" ]; then
    CROSS_CFG="/tmp/qemu-\(vmName)-cross.cfg"
    sed 's/type = "q35"/type = "pc"/' "$CFG_FILE" > "$CROSS_CFG"
    CFG_FILE="$CROSS_CFG"
    MISC_FLAGS="-nodefaults"
    echo "  Cross-arch: using pc machine type + -nodefaults (host=$_XARCH)"
  fi
  """
  )
  # ── Networking ──
  # QEMU --readconfig can define [device] for the NIC but cannot define [netdev]
  # with hostfwd port forwarding (hostfwd is not a --readconfig-supported option).
  NET_FLAGS="-netdev user,id=net0,hostfwd=tcp::${PORT}-:80"

  # ── Display / Serial / Monitor ──
  if [ "$BACKGROUND" = "1" ]; then
    SERIAL_SOCK="/tmp/qemu-\(vmName)-serial.sock"
    MONITOR_SOCK="/tmp/qemu-\(vmName)-monitor.sock"
    DISPLAY_FLAGS="-display none"
    DISPLAY_FLAGS="$DISPLAY_FLAGS -chardev socket,id=monitor0,path=$MONITOR_SOCK,server=on,wait=off"
    DISPLAY_FLAGS="$DISPLAY_FLAGS -mon chardev=monitor0,mode=readline"
    DISPLAY_FLAGS="$DISPLAY_FLAGS -chardev socket,id=serial0,path=$SERIAL_SOCK,server=on,wait=off"
    DISPLAY_FLAGS="$DISPLAY_FLAGS -serial chardev:serial0"
  else
    # Foreground: serial on stdio for interactive use
    DISPLAY_FLAGS="-nographic"
  fi

  # ── Assemble and run ──
  # shellcheck disable=SC2086
  CMD="$QEMU \\
    --readconfig $CFG_FILE \\
    $ACCEL_FLAGS \\
    $CPU_FLAGS \\
    $PFLASH_FLAGS \\
    $MISC_FLAGS \\
    $NET_FLAGS \\
    $DISPLAY_FLAGS \\
    ${QEMU_EXTRA:-}"

  if [ "$DRY_RUN" = "1" ]; then
    echo "$CMD"
    exit 0
  fi

  echo "Starting \(vmName) (port $PORT, accel=$ACCEL)..."
  if [ "$BACKGROUND" = "1" ]; then
    nohup sh -c "exec $CMD" >/tmp/qemu-\(vmName).log 2>&1 &
    echo $! > /tmp/qemu-\(vmName).pid
    echo "QEMU PID=$! — log: /tmp/qemu-\(vmName).log"
    echo "Serial:  socat - UNIX-CONNECT:$SERIAL_SOCK"
    echo "Monitor: socat - UNIX-CONNECT:$MONITOR_SOCK"
  else
    exec $CMD
  fi
  """
